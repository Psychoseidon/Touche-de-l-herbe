# Postgres (Neon) - provisionné via l'intégration Vercel Marketplace
# (`vercel integration add neon`). DATABASE_URL = connexion poolée (app),
# DATABASE_URL_UNPOOLED = connexion directe (migrations Prisma).
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

AUTH_SECRET=""

# Realtime chat (Pusher) - optional, falls back to polling if unset
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Photo uploads (Vercel Blob) - requis pour le drag-and-drop de photos
# (`vercel blob create-store <name> --access public --yes` provisionne et
# remplit cette variable automatiquement)
BLOB_READ_WRITE_TOKEN=""

# Donations (Stripe) - optional, /donate shows a placeholder if unset
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Tâches planifiées (Vercel Cron) - protège /api/cron/*, optionnel en local
CRON_SECRET=""

# Suggestions de sorties externes
#
# 1) Open Data Paris (que-faire-a-paris-) : aucune clé requise, toujours actif.
#    Source officielle de la Ville de Paris (concerts, expos, ateliers...),
#    ~2700 événements à venir. Paris uniquement. Voir src/lib/paris-opendata.ts.
#
# 2) OpenAgenda - optionnel, désactivé si absent. Couvre le reste de la France
#    (métropoles : Marseille, Nantes, Bordeaux, Lille, Toulouse, Rennes,
#    Rouen... + quelques villes plus petites). Clé publique gratuite :
#    https://openagenda.com/settings/apiKey
#    OPENAGENDA_AGENDAS : liste d'agendas à interroger en parallèle, séparés
#    par des virgules, au format "uid" ou "uid:slug". Exemple :
#      OPENAGENDA_AGENDAS="12345:agenda-paris,67890:paris-culture"
#    Certaines grandes villes (Lyon, Nice, Toulon, Grenoble...) n'ont pas
#    d'agenda OpenAgenda actif trouvé à ce jour — elles ne montrent que les
#    sorties créées par les membres, pas de suggestions externes.
OPENAGENDA_PUBLIC_KEY=""
OPENAGENDA_AGENDAS=""
