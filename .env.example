# Postgres (Neon) - provisionné via l'intégration Vercel Marketplace
# (`vercel integration add neon`). DATABASE_URL = connexion poolée (app),
# DATABASE_URL_UNPOOLED = connexion directe (migrations Prisma).
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

AUTH_SECRET=""

# Realtime chat (Pusher) - optional, falls back to polling if unset
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Photo uploads (Uploadthing) - optional, falls back to plain URL input if unset
UPLOADTHING_TOKEN=""

# Donations (Stripe) - optional, /donate shows a placeholder if unset
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Tâches planifiées (Vercel Cron) - protège /api/cron/*, optionnel en local
CRON_SECRET=""

# Suggestions de sorties externes (OpenAgenda) - optionnel, désactivé si absent.
# Clé publique gratuite : https://openagenda.com/settings/apiKey
# OPENAGENDA_AGENDA_UID : identifiant de l'agenda à suivre (une ville pour la phase de test)
# OPENAGENDA_AGENDA_SLUG : slug de cet agenda, pour construire le lien "Voir la source"
OPENAGENDA_PUBLIC_KEY=""
OPENAGENDA_AGENDA_UID=""
OPENAGENDA_AGENDA_SLUG=""
